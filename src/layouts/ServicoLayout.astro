---
import "../styles/globals.css";
import { Navbar } from "../components/Navbar";
import { Footer } from "../components/Footer";
import { getContato } from "../lib/directus";
import { processarConteudoHTML } from "../lib/helpers";

interface Props {
  titulo: string;
  subtitulo: string;
  imagem?: string;
  conteudo: string;
}

const { titulo, subtitulo, imagem, conteudo } = Astro.props;

// Processa o conteúdo para garantir tags <p>
const conteudoProcessado = processarConteudoHTML(conteudo);

const contatoData = await getContato();
const contatoProps = contatoData ? {
  telefone: contatoData.telefone,
  instagram: contatoData.instagram,
} : {};
---

<!doctype html>
<html lang="pt-BR" class="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{titulo} · Juliana Tardivo · Astrologia Humanizada</title>
    <meta
      name="description"
      content={subtitulo}
    />
    <meta property="og:title" content={`${titulo} · Juliana Tardivo`} />
    <meta
      property="og:description"
      content={subtitulo}
    />
    <meta property="og:type" content="article" />
    {imagem && <meta property="og:image" content={imagem} />}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;0,700;1,400;1,600&family=Inter:wght@300;400;500;600&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="dark">
    <div class="relative min-h-screen text-foreground overflow-x-hidden">
      <Navbar client:load />
      <main>
        <!-- Botão Voltar -->
        <div class="hidden md:block fixed top-38 left-0 right-0 z-50 pointer-events-none">
          <div class="mx-auto max-w-7xl px-6">
            <a 
              href="/#servicos" 
              class="group flex items-center gap-2 text-sm text-muted-foreground hover:text-gold transition-colors pointer-events-auto w-fit"
              aria-label="Voltar para serviços"
            >
              <svg 
                xmlns="http://www.w3.org/2000/svg" 
                width="20" 
                height="20" 
                viewBox="0 0 24 24" 
                fill="none" 
                stroke="currentColor" 
                stroke-width="2" 
                stroke-linecap="round" 
                stroke-linejoin="round"
                class="transition-transform group-hover:-translate-x-1"
              >
                <path d="m15 18-6-6 6-6"/>
              </svg>
              <span class="hidden md:inline">Voltar</span>
            </a>
          </div>
        </div>

        <!-- Hero Section -->
        <section class="relative min-h-[50vh] flex items-center justify-center pt-32 pb-20">
          <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top,_var(--tw-gradient-stops))] from-gold/10 via-background to-background" />
          
          <div class="mx-auto max-w-4xl px-6 text-center relative z-10">
            <p class="text-xs uppercase tracking-[0.3em] text-gold mb-4">Serviço</p>
            <h1 class="font-display text-5xl md:text-6xl lg:text-7xl leading-tight mb-6">
              {titulo}
            </h1>
            <p class="text-xl md:text-2xl text-muted-foreground italic">{subtitulo}</p>
          </div>
        </section>

        <!-- Content Section -->
        <section class="relative py-20">
          <div class="mx-auto max-w-4xl px-6">
            {imagem && (
              <div class="mb-16 rounded-3xl overflow-hidden border border-gold/15">
                <img 
                  src={imagem} 
                  alt={titulo} 
                  class="w-full h-auto object-cover"
                />
              </div>
            )}
            
            <div class="prose prose-invert prose-lg max-w-none">
              <div class="sspace-y-4 text-muted-foreground leading-relaxed" set:html={conteudoProcessado} />
            </div>

            <!-- CTA Section -->
            <div class="mt-16 p-10 glass-strong rounded-3xl border border-gold/15 text-center">
              <h3 class="font-display text-3xl mb-4">Ficou com alguma dúvida?</h3>
              <p class="text-muted-foreground mb-8">Entre em contato para agendar seu atendimento</p>
              <a
                href={`https://wa.me/55${contatoProps.telefone}?text=${encodeURIComponent(`Olá Juliana, gostaria de saber mais sobre ${titulo}`)}`}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-2 px-8 py-4 bg-gold text-background font-medium rounded-full hover:bg-gold/90 transition-colors"
              >
                Agendar Consulta
              </a>
            </div>
          </div>
        </section>
      </main>
      <Footer client:visible {...contatoProps} />
    </div>
  </body>
</html>
